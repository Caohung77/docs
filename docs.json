{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SkillDiscs",
  "colors": {
    "primary": "#F5A623",
    "light": "#FBBF24",
    "dark": "#D97706"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["index", "quickstart", "authentication"]
          },
          {
            "group": "Guides",
            "pages": ["guides/llm-agents", "guides/rate-limits", "guides/errors"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "api-reference/introduction",
              "api-reference/search",
              "api-reference/list-disks",
              "api-reference/get-disk",
              "api-reference/batch"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://skilldiscs.com",
          "icon": "browser"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/Caohung77/skilldisc",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Settings",
        "href": "https://skilldiscs.com/settings"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://skilldiscs.com"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Caohung77/skilldisc"
    }
  }
}
